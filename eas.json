{
  "cli": {
    "version": ">= 3.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true
      },
      "android": {
        "buildType": "apk"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": false,
        "resourceClass": "m-medium"
      },
      "env": {
        "ENVIRONMENT": "preview",
        "EXPO_IMAGE_UTILS_NO_SHARP": "1",
        "EXPO_NO_WEB": "1",
        "CI": "1"
      }
    },
    "production": {
      "android": {
        "buildType": "app-bundle"
      },
      "ios": {
        "simulator": false,
        "resourceClass": "m-medium",
        "autoIncrement": true
      },
      "env": {
        "ENVIRONMENT": "production",
        "EXPO_IMAGE_UTILS_NO_SHARP": "1",
        "EXPO_NO_WEB": "1"
      }
    }
  },
  "submit": {
    "production": {
      "android": {
        "track": "production",
        "releaseStatus": "draft"
      },
      "ios": {
        "ascAppId": "6762679904"
      }
    }
  }
}
